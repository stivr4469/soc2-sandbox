<!DOCTYPE html>
<html>
<head>
    <title>SOC 2 Compliance Report</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1a1a2e; color: #e1e1e1; margin: 0; padding: 20px; }
        .header { text-align: center; margin-bottom: 40px; }
        .summary-container { display: flex; justify-content: space-around; margin-bottom: 40px; }
        .card { background-color: #16213e; padding: 20px; border-radius: 10px; text-align: center; width: 25%; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .card h3 { margin: 0; font-size: 14px; text-transform: uppercase; color: #999; }
        .card .value { font-size: 48px; font-weight: bold; margin-top: 10px; }
        .card.pass .value { color: #2ecc71; }
        .card.fail .value { color: #e74c3c; }
        .card.pending .value { color: #f39c12; }
        table { width: 100%; border-collapse: collapse; background-color: #16213e; border-radius: 10px; overflow: hidden; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #1a1a2e; }
        th { background-color: #0f3460; color: #fff; text-transform: uppercase; font-size: 12px; }
        .badge { padding: 5px 10px; border-radius: 4px; font-size: 11px; font-weight: bold; }
        .sev-critical { background-color: #e74c3c; color: #fff; }
        .sev-high { background-color: #e67e22; color: #fff; }
        .sev-medium { background-color: #f1c40f; color: #000; }
        .sev-low { background-color: #3498db; color: #fff; }
        .footer { text-align: center; margin-top: 40px; color: #555; font-size: 12px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>SOC 2 Type II — Compliance Report</h1>
        <p>Generated at: {{ generated_at }}</p>
        <p>Framework: {{ framework }}</p>
    </div>

    <div class="summary-container">
        <div class="card pass">
            <h3>PASS</h3>
            <div class="value">{{ summary.pass }}</div>
        </div>
        <div class="card fail">
            <h3>FAIL</h3>
            <div class="value">{{ summary.fail }}</div>
        </div>
        <div class="card pending">
            <h3>PENDING</h3>
            <div class="value">{{ summary.pending }}</div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Control</th>
                <th>Severity</th>
                <th>Finding</th>
                <th>Source</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            {% for v in violations %}
            <tr>
                <td>{{ v.control_code }}</td>
                <td><span class="badge sev-{{ v.severity|lower }}">{{ v.severity }}</span></td>
                <td>{{ v.finding }}</td>
                <td>{{ v.source }}</td>
                <td>{{ v.created_at[:19] }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Generated by Compliance Sandbox Auditor
    </div>
</body>
</html>
